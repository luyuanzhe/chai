new file mode 100644
index 0000000..a7a6d9e
--- /dev/null
+++ b/lib/chai/utils/warn.js
@@ -0,0 +1,10 @@
+import {config} from '../config.js';
+
+/**
+ * @param {string} message
+ */
+export function warn(message) {
+  if (config.enableWarning) {
+    console.warn(message);
+  }
+}
